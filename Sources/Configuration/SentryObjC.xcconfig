#include "DeploymentTargets.xcconfig"

ARCHS = $(ARCHS_STANDARD) arm64e
ARCHS[sdk=*simulator] = $(ARCHS_STANDARD)

SWIFT_ACTIVE_COMPILATION_CONDITIONS_DebugV10 = SDK_V10 DEBUG
SWIFT_ACTIVE_COMPILATION_CONDITIONS_DebugV10WithKSCrash = ENABLE_KSCRASH SDK_V10 DEBUG
SWIFT_ACTIVE_COMPILATION_CONDITIONS_ReleaseV10 = SDK_V10
SWIFT_ACTIVE_COMPILATION_CONDITIONS_ReleaseV10WithKSCrash = ENABLE_KSCRASH SDK_V10
SWIFT_ACTIVE_COMPILATION_CONDITIONS_Test = SENTRY_TEST
SWIFT_ACTIVE_COMPILATION_CONDITIONS_TestV10 = SDK_V10 SENTRY_TEST
SWIFT_ACTIVE_COMPILATION_CONDITIONS_TestV10WithKSCrash = ENABLE_KSCRASH SDK_V10 SENTRY_TEST
SWIFT_ACTIVE_COMPILATION_CONDITIONS_TestCI = SENTRY_TEST_CI
SWIFT_ACTIVE_COMPILATION_CONDITIONS = $(SWIFT_ACTIVE_COMPILATION_CONDITIONS_$(CONFIGURATION))

GCC_PREPROCESSOR_DEFINITIONS_DebugV10 = SDK_V10=1 DEBUG=1
GCC_PREPROCESSOR_DEFINITIONS_DebugV10WithKSCrash = ENABLE_KSCRASH=1 SDK_V10=1 DEBUG=1
GCC_PREPROCESSOR_DEFINITIONS_ReleaseV10 = SDK_V10=1 RELEASE=1
GCC_PREPROCESSOR_DEFINITIONS_ReleaseV10WithKSCrash = ENABLE_KSCRASH=1 SDK_V10=1 RELEASE=1
GCC_PREPROCESSOR_DEFINITIONS_Test = DEBUG=1 SENTRY_TEST=1
GCC_PREPROCESSOR_DEFINITIONS_TestV10 = SDK_V10=1 DEBUG=1 SENTRY_TEST=1
GCC_PREPROCESSOR_DEFINITIONS_TestV10WithKSCrash = ENABLE_KSCRASH=1 SDK_V10=1 DEBUG=1 SENTRY_TEST=1
GCC_PREPROCESSOR_DEFINITIONS_TestCI = DEBUG=1 SENTRY_TEST=1 SENTRY_TEST_CI=1
GCC_PREPROCESSOR_DEFINITIONS = $(GCC_PREPROCESSOR_DEFINITIONS_$(CONFIGURATION))
